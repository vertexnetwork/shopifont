# --------------------------------------------------------------------
# Identity (canonical contract — every spoke ships these)
# --------------------------------------------------------------------

# Brand name as shown to users.
NEXT_PUBLIC_SITE_NAME=Shopifont

# ≤12 chars; used for manifest short_name and consent localStorage key.
NEXT_PUBLIC_SITE_SHORT_NAME=Shopifont

# Bare hostname (no protocol).
NEXT_PUBLIC_SITE_DOMAIN=shopifont.app

# Canonical absolute URL — drives canonical tags, sitemap, schema, og:url.
# Set this in Vercel as a Production env var pointing at your custom domain.
NEXT_PUBLIC_SITE_URL=https://shopifont.app

# Long description used by OG, llms.txt header, and metadata fallbacks.
NEXT_PUBLIC_SITE_DESCRIPTION=Generate copy-paste @font-face CSS, settings_schema.json, and CSS variable overrides for any Shopify OS 2.0 theme. Conversion-optimized typography without layout shifts.

# Surfaced on /contact and security.txt.
NEXT_PUBLIC_SITE_CONTACT_EMAIL=hello@shopifont.app

# --------------------------------------------------------------------
# SEO verification (paste tokens from Search Console / Bing Webmaster)
# --------------------------------------------------------------------

NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --------------------------------------------------------------------
# Analytics
# --------------------------------------------------------------------

# Vercel Analytics + Speed Insights are auto-detected on Vercel
# deployments and no-op locally; this var is a global kill-switch.
NEXT_PUBLIC_VERCEL_ANALYTICS=1

# Microsoft Clarity project ID — heatmaps + session recordings. Free,
# unlimited. Get the 10-char ID from clarity.microsoft.com → your
# project → Setup. Loaded only after consent (cookie banner).
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Plausible domain. Match the value of your Plausible site
# (e.g. shopifont.app). Cookie-free, GDPR-compliant.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional GA4 property.
# NEXT_PUBLIC_GA_ID=

# --------------------------------------------------------------------
# Ad provider switch (manual swap — never set two at once)
# --------------------------------------------------------------------

# One of: "none", "adsense", "mediavine", "carbon".
# Mediavine Journey RPM ($8–$15) typically beats raw AdSense at scale,
# so this is the long-run target once Journey approval lands.
NEXT_PUBLIC_AD_PROVIDER=none

# Google AdSense publisher ID — looks like ca-pub-1234567890123456.
# Production value (set in Vercel): ca-pub-6985819972152617
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Mediavine Grow Faves site ID. Begins the 30-day Journey authentication
# window the moment it loads in production.
# NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Carbon Ads (developer-friendly indie ad network).
# NEXT_PUBLIC_CARBONADS_SERVE_ID=
# NEXT_PUBLIC_CARBONADS_PLACEMENT=

# AdSense ad-unit slot IDs (spoke-specific extension to the hub
# template). Each slot ID is a 10-digit number from AdSense → Ads →
# Ad units → "By ad unit."
# NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_LEADERBOARD=
# NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_INCONTENT=
# NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_SIDEBAR=

# --------------------------------------------------------------------
# Affiliate slots (Shopifont ships TWO; spec §10 acknowledges multi-
# affiliate as DIVERGENT but allowed when documented)
# --------------------------------------------------------------------

NEXT_PUBLIC_AFFILIATE_ENABLED=1
NEXT_PUBLIC_AFFILIATE_URL=https://www.creativefabrica.com/ref/24727168/
NEXT_PUBLIC_AFFILIATE_LABEL=Creative Fabrica
NEXT_PUBLIC_AFFILIATE_PROVIDER=creative-fabrica

# --------------------------------------------------------------------
# Email capture (Resend)
# --------------------------------------------------------------------

# Server-side only. Sending key with audience write scope.
# RESEND_API_KEY=

# Resend Audience ID — the audience the /api/subscribe route writes
# new contacts to. Find it in resend.com/audiences.
# RESEND_AUDIENCE_ID=

# --------------------------------------------------------------------
# Pro tier (opt-in, Stripe)
# --------------------------------------------------------------------

# NEXT_PUBLIC_PRO_ENABLED=0
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_YEARLY=

# --------------------------------------------------------------------
# Embed widget
# --------------------------------------------------------------------

NEXT_PUBLIC_EMBED_ENABLED=1
