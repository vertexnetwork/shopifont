# Public site URL — used for canonical tags, sitemap, schema, og:url.
# Set this in Vercel as a Production env var pointing at your custom domain.
NEXT_PUBLIC_SITE_URL=https://shopifont.app

# Mediavine Grow Faves site ID. Begins the 30-day Journey authentication
# window the moment it loads in production. The value is the
# base64-looking string ending in `=` from your Mediavine dashboard
# (looks like: U2l0ZTox...NzI5NDUx=). The site value gets passed
# verbatim to data-grow-faves-site-id on the injected script tag.
# Leaving it blank skips script injection entirely (no broken <script>
# in dev or preview).
NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Plausible domain for analytics. Match the value of your Plausible site
# (e.g. shopifont.app). Leaving it blank skips the analytics tag.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Microsoft Clarity project ID — heatmaps, session recordings, and
# rage/dead-click forensics. Free, unlimited. Get the 10-char ID from
# clarity.microsoft.com → your project → Setup. Leaving it blank skips
# the script injection.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Resend API key — used by the /api/subscribe Edge Function to add
# emails to the audience. Server-side only, never exposed to the
# browser. Get one from resend.com/api-keys (a "Sending" key with
# audience write scope is fine). Leaving it blank makes the route
# return 503 so submissions surface as a clean error rather than
# silently dropping.
RESEND_API_KEY=

# Resend Audience ID — the audience the /api/subscribe route writes
# new contacts to. Find it in resend.com/audiences (UUID in the URL
# or the "ID" column). Leaving it blank disables subscription writes.
RESEND_AUDIENCE_ID=

# Active ad network. One of: "adsense", "mediavine", or unset (no
# ads). Manual swap — do NOT set both. The Mediavine wiring stays in
# place for when Journey approval lands; flip this to "mediavine"
# then. Mediavine Journey RPM ($8–$15) typically beats raw AdSense at
# scale, so this is the long-run target.
NEXT_PUBLIC_AD_NETWORK=

# Google AdSense publisher ID — looks like ca-pub-1234567890123456.
# Production value (set in Vercel): ca-pub-6985819972152617
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=

# AdSense ad-unit slot IDs. Get these from AdSense dashboard → Ads →
# Ad units → "By ad unit." Each slot ID is a 10-digit number.
NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_LEADERBOARD=
NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_INCONTENT=
NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_SIDEBAR=
