# --------------------------------------------------------------------
# Identity (canonical contract — every spoke ships these)
# --------------------------------------------------------------------

# Brand name as shown to users.
NEXT_PUBLIC_SITE_NAME=Shopifont

# ≤12 chars; used for manifest short_name and consent localStorage key.
NEXT_PUBLIC_SITE_SHORT_NAME=Shopifont

# Bare hostname (no protocol).
NEXT_PUBLIC_SITE_DOMAIN=shopifont.app

# Canonical absolute URL — drives canonical tags, sitemap, schema, og:url.
# Set this in Vercel as a Production env var pointing at your custom domain.
NEXT_PUBLIC_SITE_URL=https://shopifont.app

# Long description used by OG, llms.txt header, and metadata fallbacks.
NEXT_PUBLIC_SITE_DESCRIPTION=Generate copy-paste @font-face CSS, settings_schema.json, and CSS variable overrides for any Shopify OS 2.0 theme. Conversion-optimized typography without layout shifts.

# Surfaced on /contact and security.txt.
NEXT_PUBLIC_SITE_CONTACT_EMAIL=hello@shopifont.app

# --------------------------------------------------------------------
# SEO verification (paste tokens from Search Console / Bing Webmaster)
# --------------------------------------------------------------------

NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --------------------------------------------------------------------
# Analytics
# --------------------------------------------------------------------

# Vercel Analytics + Speed Insights are auto-detected on Vercel
# deployments and no-op locally; this var is a global kill-switch.
NEXT_PUBLIC_VERCEL_ANALYTICS=1

# Microsoft Clarity project ID — heatmaps + session recordings. Free,
# unlimited. Get the 10-char ID from clarity.microsoft.com → your
# project → Setup. Loaded only after consent (cookie banner).
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Plausible domain. Match the value of your Plausible site
# (e.g. shopifont.app). Cookie-free, GDPR-compliant.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional GA4 property.
# NEXT_PUBLIC_GA_ID=

# --------------------------------------------------------------------
# Ad provider switch (manual swap — never set two at once)
# --------------------------------------------------------------------

# One of: "none", "adsense", "mediavine", "carbon".
# Mediavine Journey RPM ($8–$15) typically beats raw AdSense at scale,
# so this is the long-run target once Journey approval lands.
NEXT_PUBLIC_AD_PROVIDER=none

# Google AdSense publisher ID — looks like ca-pub-1234567890123456.
# Production value (set in Vercel): ca-pub-6985819972152617
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Mediavine Grow Faves site ID. Begins the 30-day Journey authentication
# window the moment it loads in production.
# NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Carbon Ads (developer-friendly indie ad network).
# NEXT_PUBLIC_CARBONADS_SERVE_ID=
# NEXT_PUBLIC_CARBONADS_PLACEMENT=

# AdSense ad-unit slot IDs (spoke-specific extension to the hub
# template). Each slot ID is a 10-digit number from AdSense → Ads →
# Ad units → "By ad unit."
# NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_LEADERBOARD=
# NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_INCONTENT=
# NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT_SIDEBAR=

# --------------------------------------------------------------------
# Affiliate partner
# --------------------------------------------------------------------
#
# The partner list is NOT env-driven — it lives in lib/site-config.ts
# (`features.affiliates`). Shopifont runs a SINGLE partner: Printify, the
# one already-live PartnerStack + cash + complement fit for the audience.
# Affiliates render on research / pSEO pages only, never the paid funnel
# (home / audit / kits), secondary to the kit. To add/remove a partner,
# edit the array in site-config — no env var to set here.

# --------------------------------------------------------------------
# Email capture (Resend)
# --------------------------------------------------------------------

# Server-side only. Sending key with audience write scope.
# RESEND_API_KEY=

# Resend Audience ID — the audience the /api/subscribe route writes
# new contacts to. Find it in resend.com/audiences.
# RESEND_AUDIENCE_ID=

# `From` address on the welcome email. OPT-IN per spoke — leave blank
# and the spoke skips the /emails call entirely. The deliverable URLs
# (checklist + return URL) are returned in the API response and
# rendered inline by the form, so the user still gets the checklist
# immediately in-browser even without email.
#
# When set, must be a Resend-verified sender. Format:
#   "Display Name <email@domain>"
# Resend free tier allows ONE verified domain per account, so only one
# spoke in the network can ship the welcome email on the free plan;
# the others deliver in-browser only. Upgrade to Resend Pro ($20/mo)
# for unlimited verified domains.
RESEND_FROM_EMAIL=

# --------------------------------------------------------------------
# Paid product: Shopify Typography Kits (Gumroad)
# --------------------------------------------------------------------

# THE master switch. Every kit upsell, the sales-page buy button, the
# audit-scorecard buy, the header CTA, and the founder banner ship DARK
# until this is set. Set it to the live Gumroad product URL the moment
# the store opens — no code change, no redeploy of logic. It also doubles
# as the Gumroad overlay's iframe origin for the CSP (lib/csp.ts).
#
# MUST be a *.gumroad.com host, e.g.:
#   https://thevertexnetwork.gumroad.com/l/shopify-typography-kits
# DO NOT use a Gumroad custom domain (e.g. kits.shopifont.app) here. The
# overlay bundle only binds the in-page modal to links whose host ends in
# `gumroad.com` (it derives the allowed host from the gumroad.js script
# tag's own origin); a custom-domain link silently falls through to a
# full-page navigation. The buyer never sees the *.gumroad.com URL anyway
# — the overlay renders it in a modal over our own page. Keep the custom
# domain as a no-JS / direct-link fallback only.
#
# NOTE: do NOT append ?wanted=true — Gumroad's overlay refuses to bind the
# modal to any link carrying it and navigates away full-page instead.
# NEXT_PUBLIC_KIT_GUMROAD_URL=

# Founder cold-start offer (server-only — never inlined to the client).
# Both must be set for the "X left" counter + founder price to activate;
# until then the offer fails closed to full price and simply stays dark.
# The coupon itself (code FOUNDER, flat $7 off, 37-use cap) is created in
# the Gumroad dashboard — these just let us read the live sales_count to
# drive the counter and match what the checkout charges.
#
# Gumroad → the product → "Product ID" (or read it off the API).
# GUMROAD_PRODUCT_ID=
# Gumroad → Settings → Advanced → Applications → "Generate access token".
# Read-only use here.
# GUMROAD_ACCESS_TOKEN=

# --------------------------------------------------------------------
# Pro tier (opt-in, Stripe)
# --------------------------------------------------------------------

# NEXT_PUBLIC_PRO_ENABLED=0
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_YEARLY=

# --------------------------------------------------------------------
# Embed widget
# --------------------------------------------------------------------

NEXT_PUBLIC_EMBED_ENABLED=1
