# Public site URL — used for canonical tags, sitemap, schema, og:url.
# Set this in Vercel as a Production env var pointing at your custom domain.
NEXT_PUBLIC_SITE_URL=https://shopifont.app

# Mediavine Grow Faves site ID. Begins the 30-day Journey authentication
# window the moment it loads in production. The value is the
# base64-looking string ending in `=` from your Mediavine dashboard
# (looks like: U2l0ZTox...NzI5NDUx=). The site value gets passed
# verbatim to data-grow-faves-site-id on the injected script tag.
# Leaving it blank skips script injection entirely (no broken <script>
# in dev or preview).
NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Plausible domain for analytics. Match the value of your Plausible site
# (e.g. shopifont.app). Leaving it blank skips the analytics tag.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
