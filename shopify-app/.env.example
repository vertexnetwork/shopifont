# Shopify App credentials — get these from your Partners dashboard
# (https://partners.shopify.com → Apps → your app → API credentials).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# OAuth scopes the App requests on install. Must match shopify.app.toml.
# write_themes is required for the Theme Asset API auto-install path.
SCOPES=write_themes

# Public URL the App backend is served from — the app.shopifont.app
# subdomain (a custom domain on the shopify-app Vercel project, NOT a
# *.vercel.app URL). This is the backend Shopify loads in the admin
# iframe; it is NOT the App Store listing the marketing site links to.
# `npm run dev` auto-overrides this with a tunnel URL locally, so it
# only matters in production. Trailing slash optional.
SHOPIFY_APP_URL=https://app.shopifont.app

# Postgres connection string for session storage. Any Postgres provider
# works (Vercel Postgres, Neon, Supabase). The adapter creates one row
# per merchant install. Free tier of any provider easily covers early
# traffic — sessions are tiny.
#
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Shopify Billing tier the app charges merchants. Single tier in PR-2.
# Update price by changing this value AND redeploying. The Billing API
# call references this name, so don't rename casually.
SHOPIFY_BILLING_PLAN_NAME="Shopifont Pro"
SHOPIFY_BILLING_PLAN_PRICE_USD=4.99
SHOPIFY_BILLING_TRIAL_DAYS=7
