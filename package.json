{
  "name": "shopifont",
  "version": "0.1.0",
  "private": true,
  "description": "Free Shopify custom-font CSS generator. Pure client-side @font-face, settings_schema.json, and CSS-variable output for Dawn and other OS 2.0 themes.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/build-llms-txt.ts && tsx scripts/build-changelog.ts",
    "build": "next build",
    "start": "serve out -l 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "next": "15.5.15",
    "prism-react-renderer": "2.4.1",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.15",
    "postcss": "8.5.1",
    "serve": "14.2.4",
    "tailwindcss": "4.2.4",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
