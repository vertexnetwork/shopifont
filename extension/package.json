{
  "name": "shopifont-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension popup for the Shopifont custom font code generator. Reuses the same React Generator component the website ships.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./scripts/build-icons.mjs && vite build",
    "icons": "node ./scripts/build-icons.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "prism-react-renderer": "2.4.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.32",
    "@tailwindcss/postcss": "4.2.4",
    "@types/chrome": "0.0.290",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "4.3.4",
    "postcss": "8.5.1",
    "sharp": "0.33.5",
    "tailwindcss": "4.2.4",
    "typescript": "5.7.3",
    "vite": "6.0.7"
  }
}
