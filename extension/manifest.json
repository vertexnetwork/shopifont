{
  "manifest_version": 3,
  "name": "Shopifont — Shopify Custom Font Code Generator",
  "short_name": "Shopifont",
  "version": "0.1.0",
  "description": "Generate @font-face, settings_schema.json, and CSS variable code for Shopify Dawn and OS 2.0 themes — without leaving your tab.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Shopifont — Custom Font Generator",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [],
  "host_permissions": [],
  "homepage_url": "https://shopifont.app",
  "minimum_chrome_version": "100"
}
