# dependencies
/node_modules
/.pnp
.pnp.*

# build output
/.next/
/out/
/build/

# extension build artifacts (the workspace has its own .gitignore;
# duplicated here so a top-level `git add -A` from the parent never
# stages built JS or node_modules even if someone bypasses the
# subdir gitignore).
extension/dist/
extension/node_modules/
extension/public/icons/icon-*.png

# Local image uploads — screenshots / mockups not intended for the repo.
image-uploads/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env
.env*.local
.env.development
.env.production

# misc
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea/

# typescript
*.tsbuildinfo
next-env.d.ts

# vitest
coverage/

# os
Thumbs.db

# lighthouse
.lighthouseci/
