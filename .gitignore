# dependencies
/node_modules
/.pnp
.pnp.*

# build output
/.next/
/out/
/build/

# extension build artifacts (the workspace has its own .gitignore;
# duplicated here so a top-level `git add -A` from the parent never
# stages built JS or node_modules even if someone bypasses the
# subdir gitignore).
extension/dist/
extension/node_modules/
extension/public/icons/icon-*.png

# shopify-app build artifacts. Same reasoning as extension/ — the
# sibling has its own .gitignore but listing them here keeps the
# top-level safe.
shopify-app/node_modules/
shopify-app/build/
shopify-app/.cache/
shopify-app/.shopify/
shopify-app/app/generated/
shopify-app/.vite/

# Local image uploads — screenshots / mockups not intended for the repo.
image-uploads/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env
.env*.local
.env.development
.env.production

# misc
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea/

# typescript
*.tsbuildinfo
next-env.d.ts

# vitest
coverage/

# os
Thumbs.db

# lighthouse
.lighthouseci/

# Claude Code agent local state — settings, transcripts, scratch.
.claude/

# Playwright artifacts
playwright-report/
test-results/
